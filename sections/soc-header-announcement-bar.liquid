{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    position: relative;
  }

  #header-group:has(> .shopify-section > header-announcement-bar[data-sticky='true']):has(#header-component[sticky]) {
    display: block !important;
    position: sticky;
    top: -1px;
    z-index: calc(var(--layer-sticky) + 1);
  }

  header-announcement-bar {
    display: block;
  }

  #header-group:has(> .shopify-section > header-announcement-bar[data-sticky='true'])
    .header-section:has(> #header-component[sticky='always']),
  #header-group:has(> .shopify-section > header-announcement-bar[data-sticky='true'])
    .header-section:has(> #header-component[sticky='scroll-up'][data-sticky-state='active']) {
    position: relative !important;
    top: 0 !important;
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: 100%;
    max-width: 680px;
    margin-inline: auto;
    padding-inline: calc(var(--button-size) * 2);
    box-sizing: border-box;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;
    place-content: center;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
    inset-inline: var(--button-size);
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  .announcement-bar__close {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-end: 0;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    color: inherit;
    border-radius: 0;
    width: var(--button-size);
    height: var(--button-size);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    z-index: 2;
  }

  .announcement-bar__close .svg-wrapper {
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    display: flex;
  }

  .announcement-bar__close:hover {
    background: transparent;
  }
{% endstylesheet %}

{% javascript %}
  class HeaderAnnouncementBar extends HTMLElement {
    #closeButton = null;

    connectedCallback() {
      const sectionId = this.dataset.sectionId;
      const storageKey = sectionId ? `header_announcement_dismissed_${sectionId}` : 'header_announcement_dismissed';

      if (sessionStorage.getItem(storageKey)) {
        this.removeAttribute('data-sticky');
        this.style.display = 'none';
        return;
      }

      this.#closeButton = this.querySelector('[data-header-announcement-close]');
      if (this.#closeButton) {
        this.#closeButton.addEventListener('click', this.#handleClose);
      }
    }

    disconnectedCallback() {
      if (this.#closeButton) {
        this.#closeButton.removeEventListener('click', this.#handleClose);
        this.#closeButton = null;
      }
    }

    #handleClose = () => {
      const sectionId = this.dataset.sectionId;
      const storageKey = sectionId ? `header_announcement_dismissed_${sectionId}` : 'header_announcement_dismissed';

      this.removeAttribute('data-sticky');
      this.style.display = 'none';
      sessionStorage.setItem(storageKey, '1');
    };
  }

  if (!customElements.get('header-announcement-bar')) {
    customElements.define('header-announcement-bar', HeaderAnnouncementBar);
  }
{% endjavascript %}
