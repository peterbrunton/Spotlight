{% comment %}
  AUTO-GENERATED FILE — DO NOT EDIT.
  Source: _components/header-announcement-bar

  Header announcement bar (sticky, dismissible)
{% endcomment %}

{% doc %}
  Header announcement slider with optional stickiness and dismiss button. Uses existing announcement blocks for slides and supports autoplay/arrows when multiple messages exist. Dismissal hides the bar for the session and removes stickiness to avoid overlap.
{% enddoc %}

<script
  src="{{ 'announcement-bar.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign autoplay = false
  if section.blocks.size > 1
    assign autoplay = true
  endif
  assign show_arrows = autoplay
  assign sticky = section.settings.enable_sticky
  assign dismissible = section.settings.dismissible
  assign color_scheme = section.settings.color_scheme
  assign section_width = section.settings.section_width
  assign divider_width = section.settings.divider_width
  assign speed = section.settings.speed
  assign z_index = section.settings.z_index
-%}

<div class="section-background color-{{ color_scheme }}"></div>
<header-announcement-bar
  data-section-id="{{ section.id }}"
  {% if sticky %}
    data-sticky="true"
  {% endif %}
  {% if show_arrows %}
    data-show-arrows="true"
  {% endif %}
  {% if dismissible %}
    data-dismissible="true"
  {% endif %}
>
  <aside
    class="announcement-bar spacing-style section section--{{ section_width }} color-{{ color_scheme }}"
    style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ divider_width }}px; --announcement-z: {{ z_index }};"
  >
    <announcement-bar-component
      class="announcement-bar__slider"
      {% if autoplay %}
        autoplay="{{ speed }}" aria-live="polite"
      {% endif %}
    >
      {% if show_arrows %}
        {% render 'slideshow-arrows', icon_style: 'chevron' %}
      {% endif %}

      <div class="announcement-bar__slides">
        {% content_for 'blocks' %}
      </div>

      {% if dismissible %}
        <button
          class="announcement-bar__close"
          type="button"
          aria-label="{{ 'sections.announcement.close' | default: 'Close announcement' }}"
          data-header-announcement-close
        >
          <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
        </button>
      {% endif %}
    </announcement-bar-component>
  </aside>
</header-announcement-bar>

