{% liquid
  assign has_desktop_image = false
  assign has_desktop_video = false
  assign has_mobile_image = false
  assign has_mobile_video = false
  assign has_media = false
  
  assign desktop_media_type = section.settings.desktop_media_type
  assign mobile_media_type = section.settings.mobile_media_type
  
  if section.settings.desktop_image != blank and desktop_media_type == 'image'
    assign has_desktop_image = true
  endif
  if section.settings.desktop_video != blank and desktop_media_type == 'video'
    assign has_desktop_video = true
  endif
  if section.settings.mobile_image != blank and mobile_media_type == 'image'
    assign has_mobile_image = true
  endif
  if section.settings.mobile_video != blank and mobile_media_type == 'video'
    assign has_mobile_video = true
  endif

  if has_desktop_image or has_desktop_video or has_mobile_image or has_mobile_video
    assign has_media = true
  endif

  assign alpha = section.settings.overlay_color.alpha
  assign is_transparent = true
  if alpha == 1 and section.settings.toggle_overlay
    assign is_transparent = false
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  assign desktop_sizes = '100vw'
  assign mobile_sizes = '100vw'
  assign desktop_widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '375, 750, 828, 1080, 1200'

  # Determine section width class
  assign section_width_class = 'section--full-width'
  if section.settings.hero_width == 'page-width'
    assign section_width_class = 'section--page-width'
  endif
%}

{% capture desktop_media %}
  {%- if has_desktop_image -%}
    {%- liquid
      assign loading_attr = 'lazy'
      if section.index == 1
        assign loading_attr = 'eager'
      endif
    -%}
    {{
      section.settings.desktop_image
      | image_url: width: 3840
      | image_tag:
        width: section.settings.desktop_image.width,
        widths: desktop_widths,
        height: section.settings.desktop_image.height,
        alt: section.settings.desktop_image.alt,
        class: 'hero__image hero__image--desktop',
        sizes: desktop_sizes,
        fetchpriority: fetch_priority,
        loading: loading_attr,
        decoding: 'async'
    }}
  {%- endif -%}

  {%- if has_desktop_video -%}
    {%- if section.settings.desktop_video.preview_image -%}
      {% liquid
        assign fetch_priority_poster = 'auto'
        assign loading_attr_poster = 'lazy'
        if section.index == 1
          assign fetch_priority_poster = 'high'
          assign loading_attr_poster = 'eager'
        endif
      %}
      {{
        section.settings.desktop_video.preview_image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.desktop_video.preview_image.width,
          widths: desktop_widths,
          height: section.settings.desktop_video.preview_image.height,
          alt: section.settings.desktop_video.alt,
          class: 'hero__video-poster hero__video-poster--desktop',
          sizes: desktop_sizes,
          fetchpriority: fetch_priority_poster,
          loading: loading_attr_poster,
          decoding: 'async'
      }}
    {%- endif -%}
    {%- liquid
      assign preload_attr = 'none'
      if section.index == 1
        assign preload_attr = 'metadata'
      endif
    -%}
    {{
      section.settings.desktop_video
      | video_tag:
        poster: nil,
        autoplay: true,
        loop: true,
        controls: false,
        muted: true,
        playsinline: true,
        preload: preload_attr,
        class: 'hero__video hero__video--desktop'
    }}
  {%- endif -%}
{% endcapture %}

{% capture mobile_media %}
  {%- if has_mobile_image -%}
    {%- liquid
      assign loading_attr_mobile = 'lazy'
      assign fetch_priority_mobile = 'auto'
      if section.index == 1 and has_desktop_image == false
        assign loading_attr_mobile = 'eager'
        assign fetch_priority_mobile = 'high'
      endif
    -%}
    {{
      section.settings.mobile_image
      | image_url: width: 1200
      | image_tag:
        width: section.settings.mobile_image.width,
        widths: mobile_widths,
        height: section.settings.mobile_image.height,
        alt: section.settings.mobile_image.alt,
        class: 'hero__image hero__image--mobile',
        sizes: mobile_sizes,
        fetchpriority: fetch_priority_mobile,
        loading: loading_attr_mobile,
        decoding: 'async'
    }}
  {%- endif -%}

  {%- if has_mobile_video -%}
    {%- if section.settings.mobile_video.preview_image -%}
      {%- liquid
        assign loading_attr_mobile_poster = 'lazy'
        assign fetch_priority_mobile_poster = 'auto'
        if section.index == 1 and has_desktop_video == false
          assign loading_attr_mobile_poster = 'eager'
          assign fetch_priority_mobile_poster = 'high'
        endif
      -%}
      {{
        section.settings.mobile_video.preview_image
        | image_url: width: 1200
        | image_tag:
          width: section.settings.mobile_video.preview_image.width,
          widths: mobile_widths,
          height: section.settings.mobile_video.preview_image.height,
          alt: section.settings.mobile_video.alt,
          class: 'hero__video-poster hero__video-poster--mobile',
          sizes: mobile_sizes,
          fetchpriority: fetch_priority_mobile_poster,
          loading: loading_attr_mobile_poster,
          decoding: 'async'
      }}
    {%- endif -%}
    {%- liquid
      assign preload_attr_mobile = 'none'
      if section.index == 1 and has_desktop_video == false
        assign preload_attr_mobile = 'metadata'
      endif
    -%}
    {{
      section.settings.mobile_video
      | video_tag:
        poster: nil,
        autoplay: true,
        loop: true,
        controls: false,
        muted: true,
        playsinline: true,
        preload: preload_attr_mobile,
        class: 'hero__video hero__video--mobile'
    }}
  {%- endif -%}
{% endcapture %}

{% capture media_blurred %}
  {% comment %} Use desktop image for blur effect, fallback to mobile if no desktop {% endcomment %}
  {% if has_desktop_image %}
    {{
      section.settings.desktop_image
      | image_url: width: 1200
      | image_tag:
        width: section.settings.desktop_image.width,
        widths: '600, 800, 1200',
        height: section.settings.desktop_image.height,
        alt: '',
        class: 'hero__image',
        sizes: '100vw',
        loading: 'lazy',
        decoding: 'async'
    }}
  {% elsif has_mobile_image %}
    {{
      section.settings.mobile_image
      | image_url: width: 800
      | image_tag:
        width: section.settings.mobile_image.width,
        widths: '400, 600, 800',
        height: section.settings.mobile_image.height,
        alt: '',
        class: 'hero__image',
        sizes: '100vw',
        loading: 'lazy',
        decoding: 'async'
    }}
  {% endif %}
  
  {% if has_media == false and is_transparent %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__image' }}
  {% endif %}
{% endcapture %}

<div
  id="Hero-{{ section.id }}"
  class="hero hero--{{ section.settings.section_height }} color-{{ section.settings.color_scheme }}{% if section.blocks.size == 0 and section.settings.section_height == 'auto' %} hero--no-blocks-auto-height{% endif %}"
  style="
    --hero-border-style: {{ section.settings.border }};
    --hero-border-width: {{ section.settings.border_width }}px;
    --hero-border-opacity: {{ section.settings.border_opacity }}%;
    --blur-opacity: {{ section.settings.reflection_opacity | divided_by: 100.0 }};
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == "full-screen" %}
       --hero-min-height: 100svh;
    {% else %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
    {% comment %} Set aspect ratio based on available media {% endcomment %}
    {% if has_desktop_image %}
      --hero-desktop-media-aspect-ratio: {{ section.settings.desktop_image.aspect_ratio }};
    {% endif %}
    {% if has_mobile_image %}
      --hero-mobile-media-aspect-ratio: {{ section.settings.mobile_image.aspect_ratio }};
    {% endif %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
  {% if section.settings.blurred_reflection and has_desktop_video == false and has_mobile_video == false %}
    data-blur-shadow="true"
  {% endif %}
>
  {% if section.settings.blurred_reflection %}
    {% unless has_desktop_video and has_mobile_video or is_transparent == false %}
      <div class="hero__blurred-image">
        {{ media_blurred }}
      </div>
    {% endunless %}
  {% endif %}

  <div
    class="hero__container spacing-style section {{ section_width_class }}"
    style="{% render 's-ext-spacing-style', settings: section.settings %}"
  >
    {%- if section.settings.link != blank -%}
      <a
        href="{{ section.settings.link }}"
        class="hero__link"
        {% if section.settings.open_in_new_tab %}
          target="_blank" rel="noopener"
        {% endif %}
      ></a>
    {%- endif -%}
    
    <div class="hero__media-wrapper">
      {% liquid
        if section.settings.toggle_overlay
          render 'overlay', settings: section.settings
        endif
      %}
      
      <div class="hero__media-desktop">
        {{ desktop_media }}
      </div>
      
      <div class="hero__media-mobile">
        {{ mobile_media }}
      </div>
      
      {% if has_media == false and is_transparent %}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__image' }}
      {% endif %}
    </div>
    
    <div
      class="
        hero__content-wrapper
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
        section-content-wrapper
        {{section.settings.section_width}}
        {% if request.design_mode %}hero__content-wrapper--design-mode{% endif %}
      "
      style="{% render 'l-ext-layout-panel-style', settings: section.settings %}"
    >
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

  <style>
    .hero {
      .hero__content-wrapper {
      {% if section.settings.content_area_width != 100 %}
      @media screen and (min-width: 750px) {
        width:{{ section.settings.content_area_width }}%;
      }  
      {% endif %}

      {% if section.settings.vertical_alignment_top_position_mobile != 0 %}
      @media screen and (max-width: 749px) {
        position: relative;
        top: {{ section.settings.vertical_alignment_top_position_mobile }}%;
      }
      {% endif %}
      }
    }
  </style>
{% stylesheet %}
  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  .hero {
    position: relative;
    min-height: calc(var(--hero-min-height) - var(--hero-height-offset));
  }

  .hero[data-shopify-visual-preview] {
    --hero-min-height: 600px;
    min-height: 600px;
  }

  .hero__container {
    position: relative;
    overflow: hidden;
    border: var(--hero-border-width) var(--hero-border-style) rgb(var(--color-border-rgb) / var(--hero-border-opacity));
    min-height: inherit;
    align-items: var(--vertical-alignment-mobile);
    justify-content: var(--horizontal-alignment);
    z-index: var(--layer-base);

    @media screen and (min-width: 750px) {
      align-items: var(--vertical-alignment);
    }
  }

  .hero__content-wrapper.page-width {
    grid-column: 2 / 3;
  }

  .hero__content-wrapper {
    position: relative;
    inset: 0;
    z-index: var(--layer-flat);
    
    /* Mobile-specific layout controls */
    @media screen and (max-width: 749px) {
      align-items: var(--horizontal-alignment-mobile);
      justify-content: var(--vertical-alignment-mobile);
      gap: var(--gap-mobile);
    }
  }

  .hero__content-wrapper .group-block-content {
    position: relative;
  }

  .hero__media-wrapper {
    position: absolute;
    inset: 0;
    display: block;
  }
  
  /* Page width hero adjustments */
  .hero__container.section--page-width .hero__media-wrapper {
    /* When using page-width, media should still be full-width if specified */
    position: absolute;
    inset: 0;
  }
  
  .hero__container.section--page-width.hero__container--media-contained .hero__media-wrapper {
    /* Optional: contain media within page width */
    position: relative;
    max-width: var(--page-width);
    margin: 0 auto;
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .hero__media-desktop,
  .hero__media-mobile {
    position: absolute;
    inset: 0;
  }

  .hero__media-desktop {
    @media screen and (max-width: 749px) {
      display: none;
    }
  }

  .hero__media-mobile {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .hero--auto,
  .hero--auto .hero__image,
  .hero--auto .hero__video {
    aspect-ratio: var(--hero-desktop-media-aspect-ratio);
    @media screen and (max-width: 749px) {
      aspect-ratio: var(--hero-mobile-media-aspect-ratio);
    }
  }

  .hero--auto .hero__container {
    min-height: 100%;
  }

  .hero--no-blocks-auto-height {
    :is(.hero__image, .hero__video) {
      width: 100%;
      aspect-ratio: auto;
    }

    .hero__media-wrapper {
      position: relative;
    }
  }

  .hero__image,
  .hero__video,
  .hero__video-poster {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center center;
    overflow: hidden;
    position: relative;
    z-index: var(--layer-base);
  }

  .hero__video-poster {
    position: absolute;
  }

  .hero__link {
    position: absolute;
    inset: 0;
    grid-column: 1 / -1;
  }

  .hero__media-wrapper,
  .hero__content-wrapper {
    pointer-events: none;

    :is(a, button, input, textarea, select) {
      pointer-events: auto;
    }
  }

  .hero__content-wrapper--design-mode * {
    pointer-events: auto;
  }

  .hero[data-blur-shadow='true'] {
    --blurred-reflection-filter-saturate: saturate(1.5);
    --blurred-reflection-mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);
    --blurred-reflection-box-shadow: rgb(0 0 0 / 5%) 0 0 1rem;
    --blurred-reflection-filter-blur: blur(20px);
    --blurred-reflection-scale: scale(2, 1.25);
    --blurred-reflection-padding-block-end: 60px;
  }

  .hero[data-blur-shadow='true'] .hero__container {
    overflow: inherit;
  }

  .hero[data-blur-shadow='true'] .hero__container::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: var(--blurred-reflection-box-shadow);
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: -1;
  }

  .hero__blurred-image {
    position: absolute;
    inset: 0;
    z-index: -1;
    mask-image: var(--blurred-reflection-mask-image);
    filter: var(--blurred-reflection-filter-saturate);
    pointer-events: none;
    transform: translateY(50%);
    overflow: hidden;
  }

  .hero__blurred-image img,
  .hero__blurred-image svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: var(--blurred-reflection-filter-blur);
    opacity: var(--blur-opacity);
    transform: var(--blurred-reflection-scale);
    padding-block-end: var(--blurred-reflection-padding-block-end);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "t-ext-text"
    },
    {
      "type": "b-ext-button"
    },
    {
      "type": "l-ext-logo"
    },
    {
      "type": "j-ext-jumbo-text"
    },
    {
      "type": "s-ext-spacer"
    },
    {
      "type": "g-ext-group"
    },
    {
      "type": "_m-ext-marquee"
    }
  ],
  "disabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Desktop media"
    },
    {
      "type": "select",
      "id": "desktop_media_type",
      "label": "Desktop media type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "visible_if": "{{ section.settings.desktop_media_type == 'image' }}"
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop video",
      "visible_if": "{{ section.settings.desktop_media_type == 'video' }}"
    },
    {
      "type": "header",
      "content": "Mobile media"
    },
    {
      "type": "select",
      "id": "mobile_media_type",
      "label": "Mobile media type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "visible_if": "{{ section.settings.mobile_media_type == 'image' }}"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video",
      "visible_if": "{{ section.settings.mobile_media_type == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.section_link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "hero_width",
      "label": "Hero section width",
      "options": [
        {
          "value": "full-width",
          "label": "Full width"
        },
        {
          "value": "page-width",
          "label": "Page width"
        }
      ],
      "default": "full-width",
      "info": "Controls the container width. Media will still be full-width unless media containment is enabled."
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        },
        {
          "value": "row",
          "label": "t:options.horizontal"
        }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "checkbox",
      "id": "align_baseline",
      "label": "t:settings.align_baseline",
      "default": false,
      "visible_if": "{{ section.settings.vertical_alignment == 'flex-end' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "content_area_width",
      "label": "Content area width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "info": "Override content width to stop overlap of focal point",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "header",
      "content": "Mobile layout controls"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_mobile",
      "label": "Mobile alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start",
      "info": "Override alignment specifically for mobile devices"
    },
    {
      "type": "select",
      "id": "vertical_alignment_mobile",
      "label": "Mobile position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "center",
      "info": "Override position specifically for mobile devices"
    },
    {
      "type": "range",
      "id": "vertical_alignment_top_position_mobile",
      "label": "Override position from the top",
      "min": 0,
      "max": 100,
      "default": 0
    },
    {
