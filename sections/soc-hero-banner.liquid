{% comment %}
  AUTO-GENERATED FILE — DO NOT EDIT.
  Source: _components/hero-banner

  Image-first hero banner with desktop/mobile art direction and overlay content.
{% endcomment %}

{% doc %}
  Renders a lightweight hero banner section.

- Desktop + mobile image support via `<picture>`.
- Section height is naturally determined by the active image.
- Content overlays the media using the same layout-panel system as hero.
- Optional full-section link and media overlay.
{% enddoc %}

{% liquid
  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '
  assign sizes = '100vw'

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

<div class="hero-banner-wrapper section-wrapper">
  <div class="hero-banner color-{{ section.settings.color_scheme }}">
    {% if section.settings.link != blank %}
      <a
        href="{{ section.settings.link }}"
        class="hero-banner__link"
        {% if section.settings.open_in_new_tab %}
          target="_blank" rel="noopener"
        {% endif %}
      ></a>
    {% endif %}

    <div class="hero-banner__media-wrapper" data-testid="hero-banner-media-wrapper">
      {% if section.settings.toggle_overlay %}
        {% render 'overlay', settings: section.settings %}
      {% endif %}

      {% if section.settings.image_desktop != blank %}
        <picture class="hero-banner__media" data-testid="hero-banner-picture">
          {% if section.settings.image_mobile != blank %}
            <source
              media="(max-width: 749px)"
              srcset="
                {%- for mobile_width in mobile_widths_array -%}
                  {{ section.settings.image_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              "
              sizes="100vw"
              width="{{ section.settings.image_mobile.width }}"
              height="{{ section.settings.image_mobile.height }}"
            >
          {% endif %}

          {{
            section.settings.image_desktop
            | image_url: width: 3840
            | image_tag:
              width: section.settings.image_desktop.width,
              widths: widths,
              height: section.settings.image_desktop.height,
              alt: section.settings.image_desktop.alt,
              class: 'hero-banner__media-element',
              sizes: sizes,
              fetchpriority: fetch_priority,
              data-testid: 'hero-banner-desktop-image'
          }}
        </picture>
      {% else %}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-banner__media-element' }}
      {% endif %}
    </div>

    <div
      class="
        hero-banner__content-wrapper
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
        section-content-wrapper
        {{ section.settings.section_width }}
        {% if request.design_mode %}hero-banner__content-wrapper--design-mode{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
    >
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

