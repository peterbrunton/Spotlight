{% stylesheet %}
  .hero-banner {
    position: relative;
  }

  .hero-banner__media-wrapper {
    position: relative;
    line-height: 0;
  }

  .hero-banner__media,
  .hero-banner__media-element {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-banner__content-wrapper {
    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);
    pointer-events: none;
  }

  .hero-banner .hero-banner__content-wrapper.section-content-wrapper.section-content-wrapper {
    position: absolute;
    inset: 0;
    min-height: 0;
  }

  .hero-banner__content-wrapper.page-width {
    grid-column: 2 / 3;
  }

  .hero-banner__content-wrapper :is(a, button, input, textarea, select, details, summary) {
    pointer-events: auto;
  }

  .hero-banner__content-wrapper--design-mode * {
    pointer-events: auto;
  }

  .hero-banner__link {
    position: absolute;
    inset: 0;
    z-index: var(--layer-base);
  }
{% endstylesheet %}
