<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
 class="timeline-tabs section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
 data-timeline-tabs
>
 {%- liquid
 assign tabs_position = section.settings.tabs_position
 assign tabs_alignment = section.settings.tabs_alignment
 assign panel_height = section.settings.panel_height
 assign panel_min_height = 'auto'
 case panel_height
 when 'small'
 assign panel_min_height = '22rem'
 when 'medium'
 assign panel_min_height = '28rem'
 when 'large'
 assign panel_min_height = '34rem'
 when 'xlarge'
 assign panel_min_height = '60rem'
  endcase
 -%}

 {%- capture tabs_markup -%}
 <div class="timeline-tabs__nav timeline-tabs__nav--{{ tabs_alignment }}" role="tablist" aria-label="Timeline tabs">
 {%- for block in section.blocks -%}
 {%- assign tab_label = block.settings.tab_label | strip -%}
 {%- if tab_label == blank -%}
 {%- assign tab_label = 'Step ' | append: forloop.index -%}
 {%- endif -%}
 <button
 type="button"
 id="Tab-{{ block.id }}-{{ section.id }}"
 class="timeline-tabs__tab"
 role="tab"
 aria-controls="Panel-{{ block.id }}-{{ section.id }}"
 aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
 tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
 data-timeline-tab
 data-timeline-index="{{ forloop.index0 }}"
 >
 <span class="timeline-tabs__tab-label">{{ tab_label }}</span>
 </button>
 {%- endfor -%}
 </div>
 {%- endcapture -%}

 {%- if tabs_position == 'top' -%}
 <div class="timeline-tabs__controls timeline-tabs__controls--top">
 {{ tabs_markup }}
 </div>
 {%- endif -%}

 <div class="timeline-tabs__content spacing-style" style="{% render 'spacing-padding', settings: section.settings %}; --timeline-panel-min-height: {{ panel_min_height }};">
 <div class="timeline-tabs__panels" data-timeline-panels>
 {% content_for 'blocks' %}
 </div>
 </div>

 {%- if tabs_position == 'bottom' -%}
 <div class="timeline-tabs__controls timeline-tabs__controls--bottom">
 {{ tabs_markup }}
 </div>
 {%- endif -%}
</section>

