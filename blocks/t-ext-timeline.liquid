{% stylesheet %}
.timeline-tabs {
 display: grid;
 gap: 0;
 position: relative;
}

.timeline-tabs__controls {
 display: block;
}

.timeline-tabs__controls--top {
 margin-bottom: 16px;
}

.timeline-tabs__controls--bottom {
 margin-top: 16px;
}

.timeline-tabs__controls--top .timeline-tabs__nav {
 border-top: 0;
 border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
 padding-top: 0;
 padding-bottom: 10px;
}

.timeline-tabs__content {
 display: grid;
}

.timeline-tabs__nav {
 display: flex;
 flex-wrap: wrap;
 gap: 24px;
 row-gap: 10px;
 border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
 padding-top: 10px;
}

.timeline-tabs__nav--left {
 justify-content: flex-start;
}

.timeline-tabs__nav--center {
 justify-content: center;
}

.timeline-tabs__nav--right {
 justify-content: flex-end;
}

.timeline-tabs__tab {
 appearance: none;
 border: 0;
 background: transparent;
 color: rgb(var(--color-foreground-rgb) / 0.7);
 cursor: pointer;
 padding: 4px 0;
 position: relative;
 font: inherit;
}

.timeline-tabs__tab::after {
 content: "";
 position: absolute;
 left: 0;
 right: 0;
 bottom: -1px;
 height: 1.5px;
 background: currentColor;
 transform: scaleX(0);
 transform-origin: left center;
 transition: transform 0.24s ease;
}

.timeline-tabs__tab[aria-selected="true"] {
 color: var(--color-foreground);
}

.timeline-tabs__tab[aria-selected="true"]::after {
 transform: scaleX(1);
}

.timeline-tabs__tab:focus-visible {
 outline: 2px solid rgb(var(--color-foreground-rgb) / 0.32);
 outline-offset: 3px;
}

.timeline-tabs__tab-label {
 display: block;
 line-height: 1.1;
 font-weight: 500;
 letter-spacing: 0.02em;
 text-transform: uppercase;
 font-size: 0.875rem;
}

.timeline-tabs__panels {
 position: relative;
}

.timeline-step {
 display: grid;
 grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
 gap: 32px;
 min-height: var(--timeline-panel-min-height, auto);
 align-items: stretch;
 opacity: 1;
 transform: translateY(0);
 transition: opacity 0.26s ease, transform 0.26s ease;
}

.timeline-step[inert] {
 position: absolute;
 inset: 0;
 visibility: hidden;
 pointer-events: none;
 opacity: 0;
 transform: translateY(8px);
}

.timeline-step--media-right .timeline-step__media {
 order: 2;
}

.timeline-step--media-right .timeline-step__content {
 order: 1;
}

.timeline-step__media {
 position: relative;
 min-height: var(--timeline-media-min-height, 320px);
 height: var(--timeline-media-height, 100%);
 border-radius: var(--border-radius, 0px);
 overflow: hidden;
}

.timeline-step__media img,
.timeline-step__media video,
.timeline-step__media svg {
 position: absolute;
 inset: 0;
 width: 100%;
 height: 100%;
 object-fit: cover;
}

.timeline-step__media--adapt {
 min-height: 0;
 height: auto;
}

.timeline-step__media--adapt img,
.timeline-step__media--adapt video,
.timeline-step__media--adapt svg {
 position: static;
 display: block;
 width: 100%;
 height: auto;
 object-fit: contain;
}

.timeline-step__content {
 display: flex;
 flex-direction: column;
 justify-content: flex-start;
 gap: 10px;
 padding-block: 6px;
}

.timeline-step__content--center {
 justify-content: center;
}

.timeline-step__content--bottom {
 justify-content: flex-end;
}

.timeline-step__group {
 margin-top: 6px;
}

.timeline-step--adapt {
 min-height: auto;
}

.timeline-step--adapt .timeline-step__content {
 padding-block: 0;
}

@media screen and (max-width: 989px) {
 .timeline-step {
 grid-template-columns: 1fr;
 gap: 12px;
 }

 .timeline-step--media-right .timeline-step__media,
 .timeline-step--media-right .timeline-step__content {
 order: initial;
 }

 .timeline-tabs__nav {
 overflow-x: auto;
 flex-wrap: nowrap;
 scrollbar-width: none;
 padding-bottom: 2px;
 gap: 16px;
 }

 .timeline-step__content {
 padding-block: 0;
 }

 .timeline-step__group {
 margin-top: 0;
 }

 .timeline-tabs__nav::-webkit-scrollbar {
 display: none;
 }
}
