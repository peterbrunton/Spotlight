{% assign block_settings = block.settings %}

{% comment %} Simple media detection logic {% endcomment %}
{% liquid
  assign media_to_render = blank
  assign is_video = false
  
  # Priority 1: Check video_file setting first
  if block_settings.video_file != blank
    assign media_to_render = block_settings.video_file
    assign is_video = true
  # Priority 2: Check image_file setting  
  elsif block_settings.image_file != blank
    assign media_to_render = block_settings.image_file
    
    # Only treat as video if it has video media_type or video file extension
    if block_settings.image_file.media_type == 'video'
      assign is_video = true
    else
      assign file_url = block_settings.image_file.url | default: block_settings.image_file
      if file_url contains '.mp4' or file_url contains '.mov' or file_url contains '.webm' or file_url contains '.avi' or file_url contains '.m4v'
        assign is_video = true
      endif
    endif
  endif
%}

{% if media_to_render == blank %}
  {% comment %} Placeholder when no media selected {% endcomment %}
  <div class="placeholder-media spacing-style size-style border-style" style=" display:none; {% render 's-ext-spacing-style', settings: block_settings %}{% render 'border-override', settings: block_settings %}{% render 'size-style', settings: block_settings %}">
    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-media__image' }}
  </div>
  
{% elsif is_video %}
  {% comment %} Use video block logic {% endcomment %}
  {% capture video_style %}
    {% render 's-ext-spacing-style', settings: block_settings %}
    {% render 'border-override', settings: block_settings %}
    {% render 'size-style', settings: block_settings %}
    --size-style-aspect-ratio: {{ media_to_render.aspect_ratio | default: block_settings.aspect_ratio }};
  {% endcapture %}
  
  {% render 'video',
    video: media_to_render,
    video_class: 'spacing-style size-style border-style',
    video_autoplay: block_settings.video_autoplay,
    video_loop: block_settings.video_loop,
    video_style: video_style,
    video_preview_image: media_to_render.preview_image,
    additional_attributes: block.shopify_attributes,
    section_id: section.id
  %}
  
{% else %}
  {% comment %} Use image block logic {% endcomment %}
  {% liquid
    assign ratio = 1
    case block_settings.aspect_ratio
      when 'landscape'
        assign ratio = '16 / 9'
      when 'portrait'
        assign ratio = '4 / 5'
      when 'square'
        assign ratio = '1 / 1'
      when 'adapt'
        assign ratio = media_to_render.aspect_ratio
    endcase
    
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif
  %}
  
  {% capture image_class %}
    image-block image-block--{{ block.id }} spacing-style size-style
  {% endcapture %}
  
  {% capture image_style %}
    --ratio: {{ ratio }};
    {% render 'size-style', settings: block_settings %}
    {% render 's-ext-spacing-style', settings: block_settings %}
  {% endcapture %}
  
  {% capture image_border_style %}
    --ratio: {{ ratio }};
    {% render 'border-override', settings: block_settings %}
  {% endcapture %}
  
  {% liquid
    assign media_width_desktop = '100vw'
    assign media_width_mobile = '100vw'
    assign sizes = 'auto, (min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
    assign widths = '240, 352, 832, 1200, 1600, 1920, 2560, 3840'
  %}
  
  {% capture image_markup %}
    {{
      media_to_render
      | image_url: width: 3840
      | image_tag:
        width: media_to_render.width,
        widths: widths,
        height: media_to_render.height,
        class: 'image-block__image border-style',
        style: image_border_style,
        sizes: sizes
    }}
  {% endcapture %}
  
  {% if block_settings.link == blank %}
    <div
      class="{{ image_class }}"
      style="{{ image_style }}"
      {{ block.shopify_attributes }}
    >
      {{ image_markup }}
    </div>
  {% else %}
    <a
      href="{{ block_settings.link }}"
      class="{{ image_class }}"
      style="{{ image_style }}"
      {{ block.shopify_attributes }}
    >
      {{ image_markup }}
    </a>
  {% endif %}
{% endif %}

{% stylesheet %}
  /* Reuse image block CSS */
  .placeholder-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background-secondary);
  }
  
  .placeholder-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .image-block {
    display: flex;
    /* When the image is nested in a group, section, etc, respect the parent's horizontal alignment */
    justify-content: var(--horizontal-alignment, 'inline-start');
  }

  .image-block__image {
    object-fit: cover;
    aspect-ratio: var(--ratio);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Media",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image_file",
      "label": "Media File (Image)",
      "info": "Upload your image file here"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Media File (Video)",
      "info": "Upload your video file here - takes priority over image if both are set"
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (Images Only)",
      "info": "Optional link for images (ignored for videos)"
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop Video",
      "default": true,
      "info": "Only applies to videos"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay Video",
      "default": false,
      "info": "Only applies to videos"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "info": "For images or as fallback for videos",
      "options": [
        {
          "value": "adapt",
          "label": "Auto"
        },
        {
          "value": "portrait",
          "label": "Portrait (4:5)"
        },
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "landscape",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width (Desktop)",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit Content"
        },
        {
          "value": "fill",
          "label": "Fill"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "Width (Mobile)",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit Content"
        },
        {
          "value": "fill",
          "label": "Fill"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "Custom Width (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        {
          "value": "fit",
          "label": "Fit Content"
        },
        {
          "value": "fill",
          "label": "Fill"
        }
      ],
      "default": "fit"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "Style",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "solid",
          "label": "Solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Media",
      "category": "Basic"
    }
  ]
}
{% endschema %}