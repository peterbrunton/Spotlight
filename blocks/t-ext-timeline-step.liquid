{%- assign block_index = section.blocks | find_index: 'id', block.id -%}

{%- liquid
  assign media = block.settings.image
  if block.settings.media_type == 'video'
    assign media = block.settings.video.preview_image
  endif

  assign media_height_value = '100%'
  assign media_min_height_value = '320px'
  case block.settings.media_height
    when 'small'
      assign media_min_height_value = '240px'
    when 'medium'
      assign media_min_height_value = '320px'
    when 'large'
      assign media_min_height_value = '420px'
    when 'adapt'
      assign media_height_value = 'auto'
      assign media_min_height_value = '0px'
  endcase
-%}

<div
  role="tabpanel"
  id="Panel-{{ block.id }}-{{ section.id }}"
  aria-labelledby="Tab-{{ block.id }}-{{ section.id }}"
  class="timeline-step timeline-step--media-{{ block.settings.media_position }}{% if block.settings.media_height == 'adapt' %} timeline-step--adapt{% endif %}"
  data-timeline-panel
  tabindex="{% if block_index == 0 %}0{% else %}-1{% endif %}"
  {% if block_index > 0 %}
    inert
  {% endif %}
  {{ block.shopify_attributes }}
>
  <div
    class="timeline-step__media{% if block.settings.media_height == 'adapt' %} timeline-step__media--adapt{% endif %}"
    style="--timeline-media-height: {{ media_height_value }}; --timeline-media-min-height: {{ media_min_height_value }};"
  >
    {%- if block.settings.toggle_overlay -%}
      {% render 'overlay', settings: block.settings %}
    {%- endif -%}

    {%- if media -%}
      {%- liquid
        assign height = media.width | divided_by: media.aspect_ratio | round
        assign sizes = '(min-width: 750px) 50vw, 100vw'
        assign widths = '600, 900, 1200, 1600, 2000'
      -%}

      {%- if block.settings.media_type == 'image' -%}
        {{
          block.settings.image
          | image_url: width: 2000
          | image_tag: loading: 'lazy', widths: widths, sizes: sizes, height: height
        }}
      {%- else -%}
        {%- if block.settings.video.preview_image -%}
          {{
            block.settings.video.preview_image
            | image_url: width: 2000
            | image_tag: loading: 'lazy', widths: widths, sizes: sizes, height: height, class: 'timeline-step__video-poster'
          }}
        {%- endif -%}
        {{
          block.settings.video
          | video_tag: poster: nil, autoplay: false, loop: true, controls: false, muted: true, class: 'timeline-step__video'
        }}
      {%- endif -%}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag }}
    {%- endif -%}
  </div>

  <div class="timeline-step__content timeline-step__content--{{ block.settings.content_vertical_alignment }}">
    <div class="timeline-step__group">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Timeline step",
  "tag": null,
  "blocks": [
    {
      "type": "g-ext-group"
    },
    {
      "type": "t-ext-text"
    },
    {
      "type": "b-ext-button"
    },
    {
      "type": "i-ext-image"
    },
    {
      "type": "i-ext-icon"
    },
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "tab_label",
      "label": "Tab label",
      "default": "Step"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Content vertical alignment",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "select",
      "id": "media_height",
      "label": "Media height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image (no crop)"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "visible_if": "{{ block.settings.media_type == 'image' }}"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ block.settings.media_type == 'video' }}"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Media overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000026",
      "visible_if": "{{ block.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "solid",
      "visible_if": "{{ block.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        {
          "value": "to top",
          "label": "Up"
        },
        {
          "value": "to bottom",
          "label": "Down"
        }
      ],
      "default": "to top",
      "visible_if": "{{ block.settings.toggle_overlay and block.settings.overlay_style == 'gradient' }}"
    }
  ],
  "presets": [
    {
      "name": "Timeline step",
      "blocks": {
        "content_group": {
          "type": "g-ext-group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "align_baseline": false,
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 12,
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "custom_height": 100,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "background_media": "none",
            "video_position": "cover",
            "background_image_position": "cover",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "toggle_overlay": false,
            "overlay_color": "#00000026",
            "overlay_style": "solid",
            "gradient_direction": "to top",
            "link": "",
            "open_in_new_tab": false,
            "placeholder": "",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "step_eyebrow": {
              "type": "t-ext-text",
              "settings": {
                "text": "<p>Step one</p>",
                "type_preset": "h6",
                "width": "100%",
                "alignment": "left"
              }
            },
            "step_title": {
              "type": "t-ext-text",
              "settings": {
                "text": "<h3>Your timeline title</h3>",
                "type_preset": "h3",
                "width": "100%",
                "alignment": "left"
              }
            },
            "step_body": {
              "type": "t-ext-text",
              "settings": {
                "text": "<p>Step description text.</p>",
                "type_preset": "paragraph",
                "width": "100%",
                "alignment": "left"
              }
            }
          },
          "block_order": [
            "step_eyebrow",
            "step_title",
            "step_body"
          ]
        }
      },
      "block_order": [
        "content_group"
      ]
    }
  ]
}
{% endschema %}