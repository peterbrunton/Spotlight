{%- assign block_settings = block.settings -%}
{%- assign plain_text = block_settings.text | strip_newlines | strip_html | strip -%}
{%- assign block_index = section.blocks | find_index: 'id', block.id -%}

{%- comment -%} Process countdown date {%- endcomment -%}
{%- assign raw_ends_at = block_settings.ends_at | strip -%}
{%- assign formatted_ends_at = null -%}

{%- if raw_ends_at contains ' ' -%}
  {%- assign parts = raw_ends_at | split: ' ' -%}
  {%- assign date_part = parts[0] -%}
  {%- assign time_part = parts[1] -%}

  {%- if time_part -%}
    {%- assign time_parts = time_part | split: ':' -%}
    {%- if time_parts.size == 2 -%}
      {%- assign time_part = time_part | append: ':00' -%}
    {%- elsif time_parts.size != 3 -%}
      {%- assign time_part = '00:00:00' -%}
    {%- endif -%}
  {%- else -%}
    {%- assign time_part = '00:00:00' -%}
  {%- endif -%}

  {%- assign full_datetime = date_part | append: ' ' | append: time_part -%}
  {%- assign formatted_ends_at = full_datetime | date: '%Y-%m-%dT%H:%M:%S' -%}
{%- endif -%}

{%- comment -%} Validate date {%- endcomment -%}
{%- assign date_test = formatted_ends_at | date: '%s' -%}
{%- if date_test == blank -%}
  {%- assign formatted_ends_at = null -%}
{%- endif -%}

{%- unless plain_text == '' -%}
  <slideshow-slide
    ref="slides[]"
    class="
      announcement-bar__slide
      text-block
      text-block--{{ block.id }}
      text-block--align-center
      text-block--full-width
      custom-typography
      {% if block_settings.font_size != "" %}custom-font-size{% endif %}
      {% if block_settings.weight != "" %}custom-font-weight{% endif %}
    "
    style="
      {% render 'typography-style', settings: block_settings, preset: 'custom' %}
      --width: 100%;
      --text-align: center;
      --line-height: 1;
    "
    {{ block.shopify_attributes }}
    aria-hidden="{% if block_index == 0 %}false{% else %}true{% endif %}"
  >
    <p class="announcement-bar__text">
      {%- if block_settings.icon != 'none' -%}
        <span class="svg-wrapper svg-wrapper--small">
          {{- 'icon-' | append: block_settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
      {%- endif -%}

      {{ block_settings.text }}

      {%- if formatted_ends_at -%}
        <span class="announcement-countdown-wrapper">
          <countdown-timer
            ends-at="{{ formatted_ends_at }}"
            expiration-behavior="{{ block_settings.expiration_behavior }}"
            paused
          >
            <span slot="days">Days</span>
            <span slot="hours">Hrs</span>
            <span slot="minutes">Mins</span>
            <span slot="seconds">Secs</span>

            <template shadowrootmode="open">
              <style>
                :host {
                  display: inline-flex;
                  font-variant-numeric: tabular-nums;
                  gap: 0.25rem;
                  --cd-unit-width: 1.8ch;
                  line-height: 1;
                  font-size: inherit;
                }
                .unit {
                  display: flex;
                  flex-direction: column;
                  align-items: center;
                  width: var(--cd-unit-width);
                  text-align: center;
                }
                .value {
                  font-weight: bold;
                }
                .label {
                  font-size: 0.7em;
                  opacity: 0.8;
                }
              </style>
              <div class="unit">
                <div class="value"><span ref="daysValue">00</span></div>
                <div class="label"><slot name="days">d</slot></div>
              </div>
              <div>:</div>
              <div class="unit">
                <div class="value"><span ref="hoursValue">00</span></div>
                <div class="label"><slot name="hours">h</slot></div>
              </div>
              <div>:</div>
              <div class="unit">
                <div class="value"><span ref="minutesValue">00</span></div>
                <div class="label"><slot name="minutes">m</slot></div>
              </div>
              <div>:</div>
              <div class="unit">
                <div class="value"><span ref="secondsValue">00</span></div>
                <div class="label"><slot name="seconds">s</slot></div>
              </div>
            </template>
          </countdown-timer>
        </span>
      {%- endif -%}

      {%- if block_settings.icon != 'none' -%}
        <span class="svg-wrapper svg-wrapper--small">
          {{- 'icon-' | append: block_settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
      {%- endif -%}
    </p>

    {%- if block_settings.link != blank -%}
      <a
        class="announcement-bar__link"
        href="{{ block_settings.link }}"
      >
        <span class="visually-hidden">
          {{ block_settings.text | strip_html }}
        </span>
      </a>
    {%- endif -%}
  </slideshow-slide>
{%- endunless -%}

<script
  src="{{ 'soc-countdown-timer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% schema %}
{
  "name": "Announcement Countdown",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "Sale ends in"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "ends_at",
      "label": "End Date & Time",
      "placeholder": "Eg. 2025-12-31 23:59",
      "info": "Format: YYYY-MM-DD HH:MM (24-hour). Time is interpreted in the visitor's local browser timezone."
    },
    {
      "type": "select",
      "id": "expiration_behavior",
      "label": "When timer ends",
      "options": [
        { "value": "none", "label": "Keep visible" },
        { "value": "hide", "label": "Hide timer" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font",
      "options": [
        { "value": "var(--font-body--family)", "label": "Body" },
        { "value": "var(--font-subheading--family)", "label": "Subheading" },
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-accent--family)", "label": "Accent" }
      ],
      "default": "var(--font-body--family)"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Size",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" },
        { "value": "1.25rem", "label": "20px" }
      ],
      "default": "1rem"
    },
    {
      "type": "select",
      "id": "weight",
      "label": "Weight",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter Spacing",
      "options": [
        { "value": "tight", "label": "Tight" },
        { "value": "normal", "label": "Normal" },
        { "value": "loose", "label": "Loose" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "case",
      "label": "Case",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "discount", "label": "Discount" },
        { "value": "love", "label": "Love" },
        { "value": "fire", "label": "Fire" }
      ],
      "default": "fire"
    }
  ],
  "presets": [
    {
      "name": "Announcement Countdown"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .announcement-countdown-wrapper {
    display: inline-flex;
    align-items: center;
    margin-inline-start: 0.5rem;
  }
{% endstylesheet %}
