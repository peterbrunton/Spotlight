{% style %}
  .line-item-property-{{ block.id }} {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    padding: 0 16px;
    margin: 0 0;

    background: transparent;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(20px) scale(0.95);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .line-item-property-{{ block.id }}.visible {
    max-height: 300px;
    opacity: 1;
    padding: 24px 16px;
    transform: translateY(0) scale(1);
    margin: 16px 0;

    background-color: var(--color-input-border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .line-item-property-{{ block.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    border-radius: 16px 16px 0 0;
    opacity: 0;
    transform: scaleX(0);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .line-item-property-{{ block.id }}.visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  .line-item-property__input-{{ block.id }} {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: 8px;
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_text_size }}px;
    font-weight: 500;
    letter-spacing: 0.3px;
    opacity: 0;
    transform: translateY(10px) scale(0.98);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    position: relative;
    z-index: 1;
  }

  .line-item-property__input-{{ block.id }}:hover {
    border-color: var(--color-input-border-hover, #B0B0B0);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
    transform: translateY(-1px);
  }

  .line-item-property-{{ block.id }}.visible .line-item-property__input-{{ block.id }} {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.2s;
  }

  .line-item-property__input-{{ block.id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
    box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .line-item-property__input-{{ block.id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    font-weight: 400;
    transition: all 0.3s ease;
  }

  .line-item-property__input-{{ block.id }}:focus::placeholder {
    opacity: 0.7;
    transform: translateY(-2px);
  }

  /* Floating label effect */
  .line-item-property__label-{{ block.id }} {
    position: absolute;
    top: 16px;
    left: 20px;
    color: {{ block.settings.placeholder_color }};
    font-size: {{ block.settings.input_text_size }}px;
    font-weight: 500;
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2;
    opacity: 0;
  }

  .line-item-property__input-{{ block.id }}:focus + .line-item-property__label-{{ block.id }},
  .line-item-property__input-{{ block.id }}:not(:placeholder-shown) + .line-item-property__label-{{ block.id }} {
    top: -8px;
    left: 16px;
    font-size: 12px;
    opacity: 1;
    background: white;
    color: {{ block.settings.placeholder_color }};
    padding: 0 8px;
  }

  .line-item-property__description-{{ block.id }} {
    margin-top: 12px;
    font-size: {{ block.settings.description_size }}px;
    font-weight: 500;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    opacity: 0;
    transform: translateY(8px) scale(0.98);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
    position: relative;
  }

  .line-item-property__description-{{ block.id }}::before {
    content: '';
    margin-right: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .line-item-property-{{ block.id }}.visible .line-item-property__description-{{ block.id }} {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.3s;
  }

  .line-item-property-{{ block.id }}.visible .line-item-property__description-{{ block.id }}::before {
    opacity: 0;
    transition-delay: 0.5s;
  }

  .line-item-property__required-{{ block.id }} {
    color: {{ block.settings.required_color }};
    font-weight: 600;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* Character counter */
  .line-item-property__counter-{{ block.id }} {
    position: absolute;
    bottom: 8px;
    right: 12px;
    font-size: 11px;
    font-weight: 600;
    color: #94a3b8;
    opacity: 0;
    transition: all 0.3s ease;
    background: rgba(255, 255, 255, 0.9);
    padding: 2px 6px;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .line-item-property__input-{{ block.id }}:focus ~ .line-item-property__counter-{{ block.id }} {
    opacity: 1;
  }

  .line-item-property__counter-{{ block.id }}.warning {
    color: #f59e0b;
  }

  .line-item-property__counter-{{ block.id }}.danger {
    color: #ef4444;
  }

  /* Mobile optimizations */
  @media screen and (max-width: 749px) {
    .line-item-property-{{ block.id }} {
      margin: 12px 0;
      border-radius: 12px;
    }

    .line-item-property-{{ block.id }}.visible {
      padding: 20px 12px;
    }

    .line-item-property__input-{{ block.id }} {
      padding: 14px 16px;
      font-size: 16px; /* Prevents zoom on iOS */
    }
  }

  /* Accessibility improvements */
  @media (prefers-reduced-motion: reduce) {
    .line-item-property-{{ block.id }},
    .line-item-property__input-{{ block.id }},
    .line-item-property__description-{{ block.id }} {
      transition: none;
    }
  }

  /* High contrast mode */
  @media (prefers-contrast: high) {
    .line-item-property-{{ block.id }}.visible {
      border: 2px solid #000;
      background: #fff;
    }

    .line-item-property__input-{{ block.id }} {
      border: 2px solid #000;
      background: #fff;
    }
  }
{% endstyle %}

