{% endcomment %}

<personalisation-line-item 
  class="line-item-property-{{ block.id }}"
  data-variant-trigger="{{ block.settings.variant_trigger | downcase }}"
  data-block-type="line-item-property"
  {{ block.shopify_attributes }}
  >
  <div class="line-item-property__input-wrapper" style="position: relative;">
    {% if block.settings.input_type == 'textarea' %}
      <textarea
        id="engraving-input-{{ block.id }}"
        name="properties[engraving]"
        class="line-item-property__input-{{ block.id }}"
        placeholder="{{ block.settings.placeholder }}"
        {% if block.settings.required %}required{% endif %}
        {% if block.settings.max_length > 0 %}maxlength="{{ block.settings.max_length }}"{% endif %}
        rows="{{ block.settings.textarea_rows }}"
        form="{{ product_form_id }}"
        >
      </textarea>
    {% else %}
      <input
        type="text"
        id="engraving-input-{{ block.id }}"
        name="properties[engraving]"
        class="line-item-property__input-{{ block.id }}"
        placeholder="{{ block.settings.placeholder }}"
        pattern="{{ block.settings.pattern }}"
        {% if block.settings.required %}required{% endif %}
        {% if block.settings.max_length > 0 %}maxlength="{{ block.settings.max_length }}"{% endif %}
        form="{{ product_form_id }}"
      >
    {% endif %}
    
    {% if block.settings.max_length > 0 %}
      <div class="line-item-property__counter-{{ block.id }}">
        <span class="current">0</span>/<span class="max">{{ block.settings.max_length }}</span>
      </div>
    {% endif %}
  </div>
  
  {% if block.settings.description != blank %}
    <small class="line-item-property__description-{{ block.id }}">
      {{ block.settings.description }}
      {% if block.settings.required %}<span class="line-item-property__required-{{ block.id }}">*</span>{% endif %}
    </small>
  {% endif %}
</personalisation-line-item>

<script>
  (function() {
    if (!customElements.get('personalisation-line-item')) {
      customElements.define('personalisation-line-item', class PersonalisationLineItem extends HTMLElement {
        constructor() {
          super();
          this.variantTrigger = this.dataset.variantTrigger;
          this.input = this.querySelector('.line-item-property__input-{{ block.id }}');
          this.counter = this.querySelector('.line-item-property__counter-{{ block.id }}');
          this.productForm = document.querySelector('product-form form, form[action*="/cart/add"]');
          this.quantityInput = document.querySelector('quantity-selector .quantity-selector__input') ||
                               document.querySelector('[name="quantity"]');

          this.setupCharacterCounter();
          this.setupInputValidation();
        }

        connectedCallback() {
          this.setupVariantListener();
          this.checkInitialVariant();
          this.setupAccessibilityFeatures();
          setTimeout(() => {
            if (!this.addToCartButton) {
              this.setupAddToCartControl();
            }
          }, 200);
        }

        setupAddToCartControl() {
          if (this.addToCartButton) return;
          
          this.addToCartButton = document.querySelector('button[type="submit"]');
          
          if (!this.addToCartButton) {
            console.warn('[Personalisation] Add to cart button not found');
            return;
          }

          this.originalButtonDisabled = this.addToCartButton.disabled;
          
          console.log('[DEBUG] Clean original text:', `"${this.originalButtonText}"`);

          console.log('[DEBUG] Original text:', `"${this.originalButtonText}"`);
          console.log('[DEBUG] Original disabled:', this.originalButtonDisabled);

          // Listen for input changes
          if (this.input) {
            console.log('[DEBUG] Input found, adding listeners');
            this.input.addEventListener('input', () => {
              console.log('[DEBUG] Input changed:', `"${this.input.value}"`);
              this.updateAddToCartState();
            });
            
            this.input.addEventListener('blur', () => {
              this.updateAddToCartState();
            });
          } else {
            console.error('[DEBUG] NO INPUT FOUND');
          }

          // Initial state check
          console.log('[DEBUG] Running initial updateAddToCartState');
          this.updateAddToCartState();
        }

        updateAddToCartState() {
          if (!this.addToCartButton) return;

          const isVisible = this.classList.contains('visible');
          const hasValue = this.input?.value.trim().length > 0;
          const isValid = this.isInputValid();

          // Force requirement when personalisation field is visible
          const shouldDisable = isVisible && (!hasValue || !isValid);

          if (shouldDisable) {
            this.disableAddToCartButton();
          } else {
            this.enableAddToCartButton();
          }
        }

        disableAddToCartButton() {
          if (!this.addToCartButton) return;

          this.addToCartButton.disabled = true;
          this.addToCartButton.setAttribute('aria-disabled', 'true');
          
          // Only visual styling - no text change
          this.addToCartButton.style.opacity = '0.6';
          this.addToCartButton.style.cursor = 'not-allowed';
          
          // Add class for additional styling
          this.addToCartButton.classList.add('personalisation-required');
        }

        enableAddToCartButton() {
          if (!this.addToCartButton) return;

          this.addToCartButton.disabled = this.originalButtonDisabled;
          this.addToCartButton.removeAttribute('aria-disabled');
          
          // Only remove visual styling - no text change
          this.addToCartButton.style.opacity = '';
          this.addToCartButton.style.cursor = '';
          
          // Remove class
          this.addToCartButton.classList.remove('personalisation-required');
        }

        isInputValid() {
          if (!this.input) return true;

          const value = this.input.value.trim();
          const pattern = this.input.getAttribute('pattern');

          // Check pattern validation (silent check, no error messages)
          if (pattern && value && !new RegExp(pattern).test(value)) {
            return false;
          }

          return true;
        }

        setupCharacterCounter() {
          if (this.input && this.counter) {
            this.input.addEventListener('input', () => {
              const current = this.input.value.length;
              const max = parseInt(this.input.getAttribute('maxlength') || '0');
              
              if (max > 0) {
                const currentSpan = this.counter.querySelector('.current');
                if (currentSpan) {
                  currentSpan.textContent = current;
                  
                  // Visual feedback based on character count
                  this.counter.classList.remove('warning', 'danger');
                  if (current > max * 0.8) {
                    this.counter.classList.add('warning');
                  }
                  if (current > max * 0.95) {
                    this.counter.classList.add('danger');
                  }
                }
              }
            });
          }
        }

        setupInputValidation() {
          if (this.input) {
            this.input.addEventListener('blur', () => {
              this.validateInput();
            });

            this.input.addEventListener('input', () => {
              // Real-time validation feedback
              this.clearValidationErrors();
            });
          }
        }

        validateInput() {
          if (!this.input) return true;

          const value = this.input.value.trim();
          const pattern = this.input.getAttribute('pattern');
          const required = this.input.hasAttribute('required');

          // Clear previous errors
          this.clearValidationErrors();

          if (required && !value) {
            this.showValidationError('This field is required');
            return false;
          }

          if (pattern && value && !new RegExp(pattern).test(value)) {
            this.showValidationError('Please enter only letters, numbers, and spaces');
            return false;
          }

          return true;
        }

        showValidationError(message) {
          this.input.style.borderColor = '#ef4444';
          this.input.style.boxShadow = '0 0 0 4px rgba(239, 68, 68, 0.1)';
          
          // Add error message if it doesn't exist
          let errorMsg = this.querySelector('.validation-error');
          if (!errorMsg) {
            errorMsg = document.createElement('div');
            errorMsg.className = 'validation-error';
            errorMsg.style.cssText = `
              color: #ef4444;
              font-size: 12px;
              margin-top: 4px;
              font-weight: 500;
              opacity: 0;
              transform: translateY(-4px);
              transition: all 0.3s ease;
            `;
            this.appendChild(errorMsg);
          }
          errorMsg.textContent = message;
          
          // Animate in
          requestAnimationFrame(() => {
            errorMsg.style.opacity = '1';
            errorMsg.style.transform = 'translateY(0)';
          });
        }

        clearValidationErrors() {
          this.input.style.borderColor = '';
          this.input.style.boxShadow = '';
          
          const errorMsg = this.querySelector('.validation-error');
          if (errorMsg) {
            errorMsg.style.opacity = '0';
            errorMsg.style.transform = 'translateY(-4px)';
            setTimeout(() => errorMsg.remove(), 300);
          }
        }

        setupAccessibilityFeatures() {
          if (this.input) {
            // Add ARIA attributes
            this.input.setAttribute('aria-describedby', `description-{{ block.id }}`);
            
            const description = this.querySelector('.line-item-property__description-{{ block.id }}');
            if (description) {
              description.id = `description-{{ block.id }}`;
            }

            // Announce changes to screen readers
            this.input.addEventListener('input', () => {
              if (this.counter) {
                const current = this.input.value.length;
                const max = parseInt(this.input.getAttribute('maxlength') || '0');
                this.input.setAttribute('aria-label', 
                  `${this.input.placeholder}. ${current} of ${max} characters used.`
                );
              }
            });
          }
        }

        setupVariantListener() {
          const variantPicker = document.querySelector('variant-picker');

          if (variantPicker) {
            const variantRadios = variantPicker.querySelectorAll('input[type="radio"][name*="Style-"]');

            variantRadios.forEach(radio => {
              radio.addEventListener('change', () => {
                this.handlePersonalizationOptionChange(radio.value);
              });
            });

            document.addEventListener('variant:change', (event) => {
              if (event.detail?.variant) {
                this.handleVariantChange(event.detail.variant);
              }
            });

            if (this.productForm) {
              this.productForm.addEventListener('change', (event) => {
                const target = event.target;
                if (target.matches('[name^="options["], [name="id"]')) {
                  this.checkCurrentVariant();
                }
              });
            }

            const initialCheckedRadio = variantPicker.querySelector('input[type="radio"]:checked');
            if (initialCheckedRadio) {
              this.handlePersonalizationOptionChange(initialCheckedRadio.value);
            }
          }
        }

        checkInitialVariant() {
          this.checkCurrentVariant();
        }

        checkCurrentVariant() {
          const selectedVariant = this.getCurrentVariant();
          if (selectedVariant) {
            this.handleVariantChange(selectedVariant);
          }
        }

        getCurrentVariant() {
          if (!this.productForm) return null;
        
          const variantIdInput = this.productForm.querySelector('input[name="id"]');
          if (!variantIdInput || !variantIdInput.value) return null;
        
          const variantId = parseInt(variantIdInput.value);
        
          const variantPicker = document.querySelector('variant-picker');
          if (variantPicker) {
            const variantScript = variantPicker.querySelector('script[type="application/json"]');
            if (variantScript) {
              try {
                const variantData = JSON.parse(variantScript.textContent);
                if (variantData && variantData.id === variantId) {
                  return variantData;
                }
              } catch (err) {
                console.warn('[Personalisation] Failed to parse variant-picker JSON:', err);
              }
            }
          }
        
          const productData = this.getProductDataFromScript();
          if (productData && productData.variants) {
            const match = productData.variants.find(v => v.id === variantId);
            if (match) {
              return match;
            }
          }
        
          return null;
        }

        getProductDataFromScript() {
          const productScript = document.querySelector('script[type="application/json"][data-product-json]');
          if (productScript) {
            try {
              return JSON.parse(productScript.textContent);
            } catch (e) {
              console.warn('[Personalisation] Error parsing product JSON:', e);
            }
          }
          return null;
        }

        handlePersonalizationOptionChange(selectedOptionValue) {
          const triggerLower = this.variantTrigger.toLowerCase();
          const selectedOptionLower = selectedOptionValue.toLowerCase();

          if (selectedOptionLower.includes(triggerLower)) {
            this.showProperty();
            if (this.quantityInput) {
              this.quantityInput.value = '1';
              this.quantityInput.disabled = true;
            }
          } else {
            this.hideProperty();
            if (this.quantityInput) {
              this.quantityInput.disabled = false;
            }
          }
        }

        handleVariantChange(variant) {
          if (!variant || !this.variantTrigger) return;

          const shouldShow = this.shouldShowForVariant(variant);

          if (shouldShow) {
            this.showProperty();
            if (this.quantityInput) {
              this.quantityInput.value = '1';
              this.quantityInput.disabled = true;
            }
          } else {
            this.hideProperty();
            if (this.quantityInput) {
              this.quantityInput.disabled = false;
            }
          }
        }

        shouldShowForVariant(variant) {
          const title = variant.title?.toLowerCase() || '';
          const trigger = this.variantTrigger.toLowerCase();

          const titleMatch = title.includes(trigger);
          const optionsMatch = variant.options?.some(opt => (opt || '').toLowerCase().includes(trigger));

          return titleMatch || optionsMatch;
        }

        showProperty() {
          this.classList.add('visible');
          if (this.input) {
            this.input.disabled = false;
            // Focus with delay for better UX
            setTimeout(() => {
              this.input.focus();
            }, 500);
          }
          
          // Announce to screen readers
          this.setAttribute('aria-live', 'polite');
          this.setAttribute('aria-label', 'Personalization options now available');
        
          this.updateAddToCartState();
        }

        hideProperty() {
          this.classList.remove('visible');
          if (this.input) {
            this.input.disabled = true;
            this.input.value = '';
            this.clearValidationErrors();
          }
          
          // Update character counter
          if (this.counter) {
            const currentSpan = this.counter.querySelector('.current');
            if (currentSpan) {
              currentSpan.textContent = '0';
            }
          }
          this.updateAddToCartState();
        }

      });
    }
  })();
</script>

{% schema %}
{
  "name": "Personalisation",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder text",
      "default": "Personalise your device"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Laser engrave up to 12 characters (letters & numbers only)</p>"
    },
    {
      "type": "checkbox",
      "id": "required",
      "label": "Required field",
      "default": false
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "text",
      "id": "variant_trigger",
      "label": "Show when variant contains",
      "default": "Personalised",
      "info": "Block will only show when the selected variant title or option contains this text"
    },
    {
      "type": "header",
      "content": "Input Settings"
    },
    {
      "type": "select",
      "id": "input_type",
      "label": "Input type",
      "options": [
        {
          "value": "text",
          "label": "Single line"
        },
        {
          "value": "textarea",
          "label": "Multi-line"
        }
      ],
      "default": "text"
    },
    {
      "type": "range",
      "id": "max_length",
      "min": 0,
      "max": 200,
      "step": 5,
      "label": "Maximum characters",
      "default": 20,
      "info": "Set to 0 for no limit"
    },
    {
      "type": "text",
      "id": "pattern",
      "label": "Regular expression pattern",
      "default": "[A-Za-z0-9 ]+"
    },
    {
      "type": "range",
      "id": "textarea_rows",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Textarea rows",
      "default": 3
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "input_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 2
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#667eea"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "rgba(255, 255, 255, 0.9)"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Input text color",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Border color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "input_focus_border_color",
      "label": "Focus border color",
      "default": "#667eea"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder color",
      "default": "#94a3b8"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#64748b"
    },
    {
