{% stylesheet %}
  @media screen and (max-width: 929px){
    #header-klarna-top-strip-promotion-badge {
      display: none;
    }
  }
  @media screen and (min-width: 930px) and (max-width: 1150px) {
    #header-klarna-top-strip-promotion-badge::part(osm-message) {
      visibility: hidden;
      position: relative;
      clip-path: inset(0 0 0 60px);
    }

    #header-klarna-top-strip-promotion-badge::part(osm-cta) {
      visibility: visible;
      position: absolute;
      right: 0;
      top: 5px;
    }
  }
  #header-klarna-top-strip-promotion-badge::part(osm-container) {
    padding-left: 0;
    padding-right: 0;
    background-color: transparent;
    font-size: 11px;
  }

  #header-klarna-top-strip-promotion-badge::part(osm-cta) {
    font-size: 11px;
  }
{% endstylesheet %}
<!-- Placement v2 -->
<klarna-placement
  id="header-klarna-top-strip-promotion-badge"
  data-key="top-strip-promotion-badge"
  data-locale="en-IE"
></klarna-placement>
