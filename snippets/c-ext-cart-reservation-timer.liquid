<script
    src="{{ 'c-ext-countdown-timer.js' | asset_url }}"
    type="module"
    fetchpriority="low"
></script>

<cart-reservation-timer duration-minutes="10">
  <countdown-timer class="cart-reservation-timer" paused expiration-behavior="none">
    <span class="cart-reservation-timer__label">Cart reserved for</span>
    <span class="cart-reservation-timer__time" aria-label="Cart reservation time remaining">
      <span class="unit"><span ref="minutesValue">10</span></span>
      <span class="sep">:</span>
      <span class="unit"><span ref="secondsValue">00</span></span>
    </span>
    <span class="cart-reservation-timer__suffix">minutes</span>
  </countdown-timer>
</cart-reservation-timer>
