{%- comment -%}
  ============================================================
  Trailing slash redirect — must run immediately
{%- endcomment -%}
<script>
  if (window.location.pathname !== '/' && window.location.pathname.slice(-1) === '/') {
    window.location.href = window.location.href.slice(0, -1);
  }
</script>

{%- comment -%}
  ============================================================
  Adaptive render-blocker patch — removes the view-transition render-blocker
  immediately on slow connections rather than waiting the base 1800ms timeout.
  Loaded without async so it runs synchronously in <head> before the base
  view-transitions.js (which is async) has a chance to execute.
{%- endcomment -%}
{% if settings.page_transition_enabled or settings.transition_to_main_product %}
  <script>
    (function () {
      const connection = navigator.connection;
      const isSlowConnection =
        connection && (connection.saveData || ['slow-2g', '2g', '3g'].includes(connection.effectiveType));
      if (isSlowConnection) {
        document.getElementById('view-transition-render-blocker')?.remove();
      }
    })();
  </script>
{% endif %}

{%- comment -%}
  ============================================================
  Trustpilot
{%- endcomment -%}

<script type="text/javascript" src="//widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js" defer></script>
<script>
  (function () {
    function initWidget(el) {
      if (window.Trustpilot) {
        window.Trustpilot.loadFromElement(el, true);
      } else {
        document.querySelector('[src*="tp.widget.bootstrap"]')?.addEventListener('load', () => {
          window.Trustpilot.loadFromElement(el, true);
        });
      }
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          el.setAttribute('data-template-id', el.dataset.tpTemplate);
          el.setAttribute('data-businessunit-id', el.dataset.tpBu);
          el.setAttribute('data-token', el.dataset.tpToken);
          el.setAttribute('data-sku', el.dataset.tpSku);
          el.classList.add('trustpilot-widget');
          initWidget(el);
          io.unobserve(el);
        });
      },
      { rootMargin: '200px' }
    );

    function observeAll() {
      document.querySelectorAll('.tp-lazy:not(.trustpilot-widget)').forEach((el) => io.observe(el));
    }

    // Watch for new cards added by infinite scroll
    const mo = new MutationObserver((mutations) => {
      let hasNew = false;
      for (const m of mutations) {
        for (const node of m.addedNodes) {
          if (
            node instanceof HTMLElement &&
            (node.classList?.contains('tp-lazy') || node.querySelector?.('.tp-lazy'))
          ) {
            hasNew = true;
            break;
          }
        }
        if (hasNew) break;
      }
      if (hasNew) observeAll();
    });

    function init() {
      observeAll();
      mo.observe(document.body, { childList: true, subtree: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('shopify:section:load', observeAll);
  })();
</script>

{%- comment -%}
  ============================================================
  Klaviyo — idempotent loader, initialises queue before library arrives
{%- endcomment -%}
<script>
  window._learnq = window._learnq || [];
  (function loadKlaviyo() {
    if (window.Klaviyo && window.Klaviyo.api) return;
    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Vqfqg4';
    document.head.appendChild(s);
  })();
</script>

{%- comment -%}
  ============================================================
  GTM / Google Ads / Clarity — deferred until user interaction or idle
{%- endcomment -%}
<script>
  window.dataLayer = window.dataLayer || [];
  window.clarity =
    window.clarity ||
    function () {
      (window.clarity.q = window.clarity.q || []).push(arguments);
    };

  function gtag() {
    dataLayer.push(arguments);
  }
  dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

  (function () {
    var scriptsLoaded = false;
    var userInteracted = false;
    var pageLoaded = document.readyState === 'complete';

    if (!pageLoaded) {
      window.addEventListener('load', function () {
        pageLoaded = true;
        checkAndLoad();
      });
    }

    function loadAllScripts() {
      if (scriptsLoaded) return;
      scriptsLoaded = true;

      var gtmScript = document.createElement('script');
      gtmScript.async = true;
      gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-M5CCBHK';
      (document.body || document.head).appendChild(gtmScript);

      var gtagScript = document.createElement('script');
      gtagScript.async = true;
      gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=AW-816577827';
      gtagScript.onload = function () {
        gtag('js', new Date());
        gtag('config', 'AW-816577827');
      };
      (document.body || document.head).appendChild(gtagScript);
      setTimeout(function () {
        var clarityScript = document.createElement('script');
        clarityScript.async = true;
        clarityScript.src = 'https://www.clarity.ms/tag/rc977bj7kf';
        (document.body || document.head).appendChild(clarityScript);
      }, 25);
    }

    function checkAndLoad() {
      if (userInteracted && pageLoaded) loadAllScripts();
    }

    function onUserInteraction() {
      userInteracted = true;
      checkAndLoad();
    }

    ['scroll', 'click', 'mousemove', 'keydown', 'touchstart'].forEach(function (event) {
      document.addEventListener(event, onUserInteraction, { passive: true, once: true });
    });

    if ('requestIdleCallback' in window) {
      requestIdleCallback(
        function () {
          if (!scriptsLoaded) {
            pageLoaded = true;
            userInteracted = true;
            loadAllScripts();
          }
        },
        { timeout: 2000 }
      );
    } else {
      setTimeout(function () {
        if (!scriptsLoaded) {
          pageLoaded = true;
          userInteracted = true;
          loadAllScripts();
        }
      }, 2000);
    }
  })();
</script>
